# Dev only: must match Express PORT in server/.env (default 5000). Your API uses 5001 — use:
VITE_API_PROXY=http://127.0.0.1:5001

# Optional production: full API base URL ending in /api
# VITE_API_URL=https://your-api.com/api

# PostHog (optional analytics)
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
