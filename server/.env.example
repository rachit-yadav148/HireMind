# Get a key: https://aistudio.google.com/apikey — see https://ai.google.dev/gemini-api/docs/quickstart
GEMINI_API_KEY=

MONGO_URI=
JWT_SECRET=
PORT=5000
CLIENT_URL=http://localhost:5173
# Optional: comma-separated extra frontend origins for CORS
# CLIENT_URLS=https://hiremind.me,https://hire-mind-five.vercel.app
BCRYPT_SALT_ROUNDS=10
ENABLE_EMAIL_OTP_VERIFICATION=false

# SMTP config for forgot-password emails
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional fallback mail provider (used if SMTP fails)
RESEND_API_KEY=
RESEND_FROM=

# Optional SMTP timeout tuning (milliseconds)
# SMTP_CONNECTION_TIMEOUT_MS=20000
# SMTP_GREETING_TIMEOUT_MS=15000
# SMTP_SOCKET_TIMEOUT_MS=30000

# Optional: model id (e.g. gemini-2.5-flash, gemini-3-flash-preview from the quickstart)
# GEMINI_MODEL=gemini-2.5-flash

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
